# Copy this file to .env and edit if you want to override defaults.
# All of these are optional — config.py has sensible defaults.

# Embedding model (must be multilingual)
EMBED_MODEL=intfloat/multilingual-e5-large

# Ollama settings
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# How many datasets to retrieve per question
TOP_K=3
